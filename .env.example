# IOCenrich — Example Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit your actual .env to version control.

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=ioc_admin
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ioc_platform

# ── Redis (Celery broker + cache) ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── URLs ──────────────────────────────────────────────────────────────────────
# Backend URL used internally by the Next.js proxy (never exposed to the browser)
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── API Key Vault ─────────────────────────────────────────────────────────────
# AES-256-GCM master key for envelope encryption of user API keys.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Changing this key in production will break decryption of existing stored keys.
VAULT_MASTER_KEY=generate_with_python_secrets_token_hex_32
VAULT_SALT=at_least_16_random_characters_here

# ── MinIO Object Storage (optional) ───────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password_here
